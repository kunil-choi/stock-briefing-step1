# .env.example — 실제 값은 절대 커밋하지 말 것. 로컬에서 .env로 복사해 채워 사용.
#
# 여기 나열된 변수 대부분은 pipeline/assets/media_providers.py의 커넥터가
# os.environ.get()으로 읽는다. 값이 비어 있으면 해당 커넥터는 자동으로
# 비활성화(빈 결과 반환)되며 에러를 던지지 않는다 — 실제 접근 권한이 생기면
# 값만 채우면 된다.

# ── 연합뉴스 (pipeline/assets/media_providers.py: YonhapProvider) ───────────
# 정식 계약 API가 아직 없어 값이 있어도 공개 검색 페이지 스크래핑으로 동작한다
# (인증 헤더만 실어 보내는 플러그인 지점).
YONHAP_API_KEY=

# ── KBS 뉴스 공개 검색 (KbsProvider) ─────────────────────────────────────────
KBS_API_KEY=

# ── KBS 내부망/내부 아카이브 (KbsInternalConnector) ──────────────────────────
# 사내망 접근 권한이 있는 환경에서만 채운다. 비어 있으면 커넥터가 항상 빈
# 리스트를 반환한다.
KBS_INTERNAL_API_BASE_URL=
KBS_INTERNAL_API_KEY=

# ── KBS 바다 (KbsBadaConnector) ──────────────────────────────────────────────
KBS_BADA_BASE_URL=https://bada.kbs.co.kr
KBS_BADA_API_KEY=

# ── 네이버 뉴스 검색 오픈API (NaverDiscoveryConnector) ───────────────────────
# 네이버 개발자센터(https://developers.naver.com/apps)에서 무료로 발급.
# 연합뉴스/KBS 원문 기사를 찾아 그 페이지의 og:image를 추출해 실제로
# 다운로드한다(yonhap/kbs 커넥터가 자체 사이트 검색으로 못 찾은 키워드를
# 보완하는 2차 경로). 확인된 원문 도메인 기준으로 YonhapProvider/KbsProvider와
# 동일하게 취급되므로(rights_review.py) 별도 검수 없이 자동 사용된다.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
ENABLE_NAVER_DISCOVERY=false

# ── 스톡 이미지 폴백 (StockPhotoConnector, Pexels) ───────────────────────────
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
ENABLE_STOCK_FALLBACK=true

# ── 다운로드 캐시 ─────────────────────────────────────────────────────────
ASSET_CACHE_DIR=./assets/cache

# ── 오프라인 시뮬레이션 ───────────────────────────────────────────────────
# 1이면 모든 실제 네트워크 요청 없이 MockProvider로 동작한다.
MEDIA_MOCK=
